NEXT_PUBLIC_THEME_DIR=ltr

# App URL (needed for Cardnet return/cancel redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── PayPal ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com  # default (sandbox)

# ─── Cardnet ───────────────────────────────────────────────────────────────
# Base URL — use QA for testing, prod for live
# CARDNET_BASE_URL=https://labservicios.cardnet.com.do  # default (QA)
# CARDNET_BASE_URL=https://ecommerce.cardnet.com.do     # production

# Credentials provided by your Cardnet account executive
CARDNET_MERCHANT_NUMBER=        # 15-char merchant ID (e.g. 349000000)
CARDNET_MERCHANT_TERMINAL=      # 12-char terminal ID
CARDNET_TOKEN=                  # Security token (Opción 3 REST only)
CARDNET_ACQUIRING_CODE=000      # 3-char acquiring institution code

# Merchant name: 40 chars total — "Terminal owner (22)CITY (13)STATE(3)CC(2)"
# Example: "DoCoolture             Santo Domingo RD"
CARDNET_MERCHANT_NAME=

# Authorize page URL for Opción 1 redirect (auto-set based on CARDNET_BASE_URL)
# NEXT_PUBLIC_CARDNET_AUTHORIZE_URL=https://labservicios.cardnet.com.do/authorize  # QA
# NEXT_PUBLIC_CARDNET_AUTHORIZE_URL=https://ecommerce.cardnet.com.do/authorize     # prod
